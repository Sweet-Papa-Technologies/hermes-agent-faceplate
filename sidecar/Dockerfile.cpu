# Faceplate sidecar — :cpu build (default).
# Bundles Piper + faster-whisper int8 + openWakeWord. The LLM (paraphrase
# fallback) lives OUTSIDE the container as a host-native `litert-lm serve`
# process — see scripts/start-litert.sh and Makefile target `litert-up`.
# The Faceplate paraphrase pass talks directly to the host LiteRT-LM URL,
# bypassing the sidecar entirely.

FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    HF_HOME=/models/hf

# System deps:
#   ffmpeg     — TTS PCM → MP3 / Opus muxing
#   curl       — healthcheck + bootstrap voice download
#   git        — pip install of HF deps that need git
#   openssl    — entrypoint random token
RUN apt-get update && apt-get install -y --no-install-recommends \
        ffmpeg \
        curl \
        ca-certificates \
        git \
        openssl \
        libxml2 \
    && rm -rf /var/lib/apt/lists/*

# ----------------------------------------------------------------- Python
WORKDIR /app
COPY pyproject.toml ./
RUN pip install --upgrade pip && pip install .

# openwakeword installed with --no-deps to skip the bogus tflite-runtime
# requirement from its setup.py. tflite-runtime has no Python ≥3.11 wheels
# and no arm64 Linux wheels; openwakeword 0.6+ defers the import to the
# Model constructor and only loads tflite/onnx based on the
# `inference_framework` parameter — we use ONNX (see backends/openwakeword_be.py).
# All real openwakeword runtime deps (scipy, sklearn, requests, mutagen, +
# onnxruntime via faster-whisper) are already satisfied by the previous step.
RUN pip install --no-deps "openwakeword>=0.6"

COPY faceplate_sidecar/ /app/faceplate_sidecar/
# Re-install in editable mode so subsequent code edits take effect on a
# `docker compose restart`. --no-deps keeps the layer thin (deps are pinned
# by the previous step).
RUN pip install --no-deps -e .

# ----------------------------------------------------------------- Defaults
COPY config.example.yaml /etc/faceplate-sidecar/config.yaml
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV FACEPLATE_BUILD=cpu

EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD curl -fsS http://127.0.0.1:8080/health || exit 1

ENTRYPOINT ["/entrypoint.sh"]
