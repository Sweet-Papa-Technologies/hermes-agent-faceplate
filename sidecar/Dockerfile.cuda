# Faceplate sidecar — :cuda build (NVIDIA 8 GB+ VRAM).
# Adds Kokoro-FastAPI for premium TTS, faster-whisper fp16 GPU paths, and
# the GPU build of LiteRT-LM (ML Drift on Linux/Windows).

FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    HF_HOME=/models/hf \
    DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.12 \
        python3.12-venv \
        python3-pip \
        ffmpeg \
        curl \
        ca-certificates \
        nodejs \
        npm \
        git \
        openssl \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3.12 /usr/bin/python && \
    python -m pip install --upgrade pip

WORKDIR /app
COPY pyproject.toml ./
RUN pip install .

# Replace the CPU ctranslate2 (transitive dep of faster-whisper) with a CUDA
# build matching the base image's CUDA 12.4 runtime. Without this, whisper
# silently runs on CPU even though the image is :cuda.
RUN pip install --force-reinstall --no-deps "ctranslate2>=4.4"

COPY faceplate_sidecar/ /app/faceplate_sidecar/
RUN pip install --no-deps -e .

# Kokoro-FastAPI is referenced by the design but no backend wires it yet
# (TODO §6.2 v1.x). Pull only when actually needed; current image skips it
# to avoid dead weight in the layer cache.
# ARG KOKORO_FASTAPI_REF=v0.4.0
# RUN git clone --depth 1 --branch "${KOKORO_FASTAPI_REF}" \
#       https://github.com/remsky/Kokoro-FastAPI.git \
#       /opt/kokoro-fastapi

# litert-lm-api-server (same as cpu build)
ARG LITERT_LM_API_SERVER_REF=v0.3.0
RUN git clone --depth 1 --branch "${LITERT_LM_API_SERVER_REF}" \
      https://github.com/imertz/litert-lm-api-server.git \
      /opt/litert-lm-api-server \
    && cd /opt/litert-lm-api-server \
    && npm install --omit=dev

ARG LITERT_LM_BINARY_VERSION=0.7.3
RUN mkdir -p /opt/litert-lm \
    && curl -fsSL "https://github.com/google-ai-edge/LiteRT-LM/releases/download/v${LITERT_LM_BINARY_VERSION}/litert_lm_main_linux_x86_64_gpu" \
       -o /opt/litert-lm/litert_lm_main \
    && chmod +x /opt/litert-lm/litert_lm_main

COPY config.example.yaml /etc/faceplate-sidecar/config.yaml
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV FACEPLATE_BUILD=cuda
ENV LITERT_LM_BACKEND=gpu

EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -fsS http://127.0.0.1:8080/health || exit 1

ENTRYPOINT ["/entrypoint.sh"]
