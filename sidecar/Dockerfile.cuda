# Faceplate sidecar — :cuda build (NVIDIA 8 GB+ VRAM).
# Adds faster-whisper fp16 GPU paths. The LLM (paraphrase fallback) runs
# OUTSIDE the container as host-native `litert-lm serve` — see
# scripts/start-litert.sh. On the host you can opt into the GPU backend
# with `LITERT_BACKEND=gpu make litert-up`.

FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    HF_HOME=/models/hf \
    DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.12 \
        python3.12-venv \
        python3-pip \
        ffmpeg \
        curl \
        ca-certificates \
        git \
        openssl \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3.12 /usr/bin/python && \
    python -m pip install --upgrade pip

WORKDIR /app
COPY pyproject.toml ./
RUN pip install .

# Replace the CPU ctranslate2 (transitive dep of faster-whisper) with a CUDA
# build matching the base image's CUDA 12.4 runtime. Without this, whisper
# silently runs on CPU even though the image is :cuda.
RUN pip install --force-reinstall --no-deps "ctranslate2>=4.4"

# See Dockerfile.cpu for why --no-deps openwakeword.
RUN pip install --no-deps "openwakeword>=0.6"

COPY faceplate_sidecar/ /app/faceplate_sidecar/
RUN pip install --no-deps -e .

COPY config.example.yaml /etc/faceplate-sidecar/config.yaml
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV FACEPLATE_BUILD=cuda

EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -fsS http://127.0.0.1:8080/health || exit 1

ENTRYPOINT ["/entrypoint.sh"]
